# ── MongoDB ─────────────────────────────────────────────────
# Same connection string as your main PayStar site
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/paystar?retryWrites=true&w=majority

# Blog uses a separate DB name to keep posts isolated
MONGODB_DB=paystar_blog

# ── JWT ─────────────────────────────────────────────────────
# Generate a strong secret: openssl rand -base64 64
JWT_SECRET=your-super-secret-jwt-key-minimum-32-characters-long

# ── App ─────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://blog.paystar.com.ng
NEXT_PUBLIC_SITE_NAME=PayStar Blog

# ── First Admin (used by /api/admin/seed only — delete after setup) ──
ADMIN_NAME=Azeez
ADMIN_EMAIL=admin@paystar.com.ng
ADMIN_PASSWORD=ChangeThisPassword123!
